# URL pública do site (usada no sitemap, canonical e Open Graph)
# Exemplo: https://marcadigital.dev.br
PUBLIC_SITE_URL=https://marcadigital.dev.br

# Google Analytics 4 — ID de medição (formato G-XXXXXXXXXX)
# Crie em: https://analytics.google.com → Administrador → Fluxos de dados → Web
PUBLIC_GA_MEASUREMENT_ID=

# ── Comandos (tudo via Docker) ──────────────────────────────────────
# Desenvolvimento:  docker compose up dev
# Produção:         docker compose --profile production up prod --build
# Build estático:   docker compose --profile build run --rm build
# Testes e2e:       docker compose --profile test run --rm test
#
# Atalhos npm (chamam docker compose):
# npm run docker:dev | docker:prod | docker:build | docker:test
