---
import { pricingPlans, formatBRL } from '../data/pricing';
import { whatsappUrl } from '../config/site';
---

<section
  id="servicos"
  class="bg-slate-50 py-16 sm:py-20"
  aria-labelledby="pricing-heading"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <p class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-brand-600">
        Serviços e valores
      </p>
      <h2
        id="pricing-heading"
        class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl"
      >
        Quanto custa.
      </h2>
      <p class="mt-3 text-base leading-relaxed text-slate-600">
        Setup uma vez + mensalidade de hospedagem e manutenção. Quem já tem
        site pode pedir diagnóstico gratuito (PDF em até 24h).
      </p>
    </div>

    <!-- 3 tiers — layout clássico de pricing -->
    <div class="mt-12 grid items-stretch gap-4 lg:grid-cols-3 lg:gap-0">
      {
        pricingPlans.map((plan, index) => (
          <article
            class:list={[
              'relative flex flex-col rounded-2xl border bg-white p-6 sm:p-7 lg:rounded-none',
              plan.featured
                ? 'z-10 border-brand-500 shadow-lg shadow-brand-900/5 lg:-my-3 lg:rounded-2xl lg:px-8 lg:py-9'
                : 'border-slate-200',
              !plan.featured && index === 0 && 'lg:rounded-l-2xl lg:border-r-0',
              !plan.featured &&
                index === pricingPlans.length - 1 &&
                'lg:rounded-r-2xl lg:border-l-0',
            ]}
          >
            {plan.featured && (
              <p class="mb-3 text-center text-[11px] font-semibold uppercase tracking-wider text-brand-600">
                Mais pedido
              </p>
            )}

            <h3 class="text-xl font-bold text-slate-900">{plan.name}</h3>
            <p class="mt-1 text-sm text-slate-500">{plan.blurb}</p>

            <div class="mt-6">
              <p class="text-xs font-medium text-slate-400">Setup</p>
              <p class="mt-1 flex flex-wrap items-baseline gap-1.5">
                <span class="text-sm text-slate-400">a partir de</span>
                <span class="text-3xl font-bold tracking-tight text-slate-900">
                  {formatBRL(plan.setupFrom)}
                </span>
              </p>
              {'setupNote' in plan && plan.setupNote && (
                <p class="mt-1.5 text-xs leading-snug text-slate-500">
                  {plan.setupNote}
                </p>
              )}
            </div>

            <div class="mt-4 rounded-lg bg-brand-50 px-3 py-2.5">
              <p class="text-sm text-brand-800">
                <span class="font-semibold">{formatBRL(plan.monthly)}/mês</span>
                <span class="text-brand-700/80">
                  {' '}
                  · hospedagem + manutenção
                </span>
              </p>
            </div>

            <ul class="mt-6 flex-1 space-y-2.5 border-t border-slate-100 pt-6">
              {plan.features.map((feature) => (
                <li class="flex gap-2.5 text-sm leading-snug text-slate-600">
                  <svg
                    class="mt-0.5 h-4 w-4 shrink-0 text-brand-600"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

            <a
              href={whatsappUrl(plan.whatsapp)}
              target="_blank"
              rel="noopener noreferrer"
              data-whatsapp-button={plan.whatsapp}
              class:list={[
                'mt-7 block rounded-lg py-2.5 text-center text-sm font-semibold transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2',
                plan.featured
                  ? 'bg-brand-600 text-white hover:bg-brand-700 focus-visible:outline-brand-600'
                  : 'bg-slate-100 text-slate-800 hover:bg-slate-200 focus-visible:outline-slate-400',
              ]}
            >
              Quero este plano
            </a>
          </article>
        ))
      }
    </div>

    <!-- Custom / Enterprise strip (Framer-style) -->
    <div class="mt-4 flex flex-col items-start justify-between gap-4 rounded-2xl border border-slate-200 bg-white px-6 py-5 sm:flex-row sm:items-center">
      <div>
        <p class="font-semibold text-slate-900">Sistemas / E-commerce</p>
        <p class="mt-1 text-sm text-slate-500">
          Escopo personalizado — setup e mensalidade sob orçamento
        </p>
      </div>
      <a
        href={whatsappUrl('quote_systems')}
        target="_blank"
        rel="noopener noreferrer"
        data-whatsapp-button="quote_systems"
        class="shrink-0 text-sm font-semibold text-brand-700 underline decoration-brand-200 underline-offset-4 hover:text-brand-800 hover:decoration-brand-400"
      >
        Pedir orçamento
      </a>
    </div>
  </div>
</section>
