---
import { siteConfig } from '../config/site';
import HeroContent from './HeroContent';

const sectionGradient =
  'linear-gradient(to right, rgba(3,13,24,0.96) 0%, rgba(3,13,24,0.94) 10%, rgba(3,13,24,0.88) 16%, rgba(3,13,24,0.78) 22%, rgba(3,13,24,0.65) 28%, rgba(3,13,24,0.50) 34%, rgba(3,13,24,0.36) 40%, rgba(3,13,24,0.22) 46%, rgba(3,13,24,0.11) 52%, rgba(3,13,24,0.04) 58%, transparent 66%)';

/* Soft LTR + bottom veil so the photo stays visible on mobile while text remains readable */
const mobileSectionGradient =
  'linear-gradient(to right, rgba(3,13,24,0.88) 0%, rgba(3,13,24,0.72) 28%, rgba(3,13,24,0.42) 48%, rgba(3,13,24,0.18) 68%, rgba(3,13,24,0.06) 82%, transparent 94%), linear-gradient(to top, rgba(3,13,24,0.55) 0%, transparent 42%)';
---

<section
  id="inicio"
  class="relative overflow-hidden bg-brand-950 text-white"
  aria-labelledby="hero-heading"
>
  <div class="absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
    <img
      src={siteConfig.assets.hero}
      alt="Notebook com dashboard de desempenho digital sobre uma mesa"
      width="2048"
      height="768"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="absolute inset-0 h-full w-full min-h-full min-w-full object-cover object-[72%_42%] sm:object-[68%_40%] lg:object-right"
    />
  </div>

  <div
    class="pointer-events-none absolute inset-0 z-[1] lg:hidden"
    style={{ background: mobileSectionGradient }}
    aria-hidden="true"
  />

  <div
    class="pointer-events-none absolute inset-0 z-[1] hidden lg:block"
    style={{ background: sectionGradient }}
    aria-hidden="true"
  />

  <HeroContent />
</section>
