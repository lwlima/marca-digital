{
  "name": "marca-digital",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "docker:dev": "docker compose up dev",
    "docker:dev:build": "docker compose up dev --build",
    "docker:prod": "docker compose --profile production up prod --build",
    "docker:build": "docker compose --profile build run --rm build",
    "docker:test": "docker compose --profile test run --rm test",
    "docker:test:build": "docker compose --profile test build test && docker compose --profile test run --rm test"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.2",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
